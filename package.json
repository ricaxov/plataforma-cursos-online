{
  "name": "ricardo-plataforma-cursos",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Plataforma de Cursos Online - React + TypeScript + JSON Server",
  "scripts": {
    "dev": "vite",
    "server": "json-server --watch db.json --port 3001",
    "start": "concurrently -n SERVER,VITE -c green,cyan \"npm:server\" \"npm:dev\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "autosave": "node scripts/autocommit.mjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "json-server": "^0.17.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  }
}
